# ─── App ───────────────────────────────────────
APP_NAME="Practice Project"
APP_VERSION="1.0.0"
DEBUG=true

# ─── CORS ───────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ─── Rate Limiting ──────────────────────────────
RATE_LIMIT_DEFAULT=100/minute

# ─── JWT ────────────────────────────────────────
# Generate a secure string using: openssl rand -hex 32
JWT_SECRET=your_super_secret_jwt_key_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=604800

# ─── MongoDB ────────────────────────────────────
MONGO_URI=mongodb://mongo:27017
MONGO_DB_NAME=practice_db

# ─── Redis ──────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=your_password_here   # uncomment if auth is enabled
REDIS_CACHE_TTL=300                   # default TTL in seconds
